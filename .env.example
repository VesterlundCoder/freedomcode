# =============================================================================
# freedomcode — .env.example
# Copy to .env and fill in your values (if any).
# Most settings have sane defaults for local use.
# =============================================================================

# ─── Ollama ──────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:32b
OLLAMA_CONTEXT_LENGTH=32768
OLLAMA_NUM_GPU=99
OLLAMA_METAL=1

# ─── Paths ───────────────────────────────────────────────────────────────────
FREEDOMCODE_ROOT=.
WORKSPACE_DIR=./workspace
SANDBOX_DIR=./sandbox
LOGS_DIR=./logs

# ─── Python ──────────────────────────────────────────────────────────────────
PYTHON_VERSION=3.12
VENV_DIR=./.venv

# ─── Aider ───────────────────────────────────────────────────────────────────
AIDER_MODEL=ollama/qwen2.5-coder:32b
AIDER_NO_AUTO_COMMITS=false
AIDER_DARK_MODE=true

# ─── MCP ─────────────────────────────────────────────────────────────────────
MCP_FILESYSTEM_SCOPE=./workspace
MCP_SHELL_ALLOW_LIST=ls,cat,grep,find,git,python3,uv,pip,echo,pwd,env,which

# ─── Docker ──────────────────────────────────────────────────────────────────
SANDBOX_PYTHON_VERSION=3.12
SANDBOX_MEMORY_LIMIT=4g
SANDBOX_CPU_LIMIT=4

# ─── Optional: External APIs (leave empty to stay fully local) ───────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GITHUB_TOKEN=
